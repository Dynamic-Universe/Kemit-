{
  "name": "KEMIT — Papiro Oscuro",
  "type": "dark",
  "colors": {
    "editor.background": "#0D0B06",
    "editor.foreground": "#E8D5A3",
    "editor.lineHighlightBackground": "#1A1508",
    "editor.selectionBackground": "#4A3810",
    "editorCursor.foreground": "#F0C040",
    "editorLineNumber.foreground": "#4A3A18",
    "editorLineNumber.activeForeground": "#C9A84C",
    "activityBar.background": "#0A0805",
    "activityBar.foreground": "#C9A84C",
    "sideBar.background": "#0D0B06",
    "statusBar.background": "#1A1008",
    "statusBar.foreground": "#C9A84C",
    "tab.activeBackground": "#1A1508",
    "tab.inactiveBackground": "#0D0B06",
    "tab.activeForeground": "#F0C040",
    "tab.inactiveForeground": "#7A6030",
    "tab.activeBorderTop": "#C9A84C",
    "terminal.background": "#080603",
    "terminal.foreground": "#E8D5A3",
    "panel.background": "#0A0805",
    "focusBorder": "#C9A84C",
    "button.background": "#3A2810",
    "button.foreground": "#F0C040",
    "dropdown.background": "#1A1508",
    "dropdown.foreground": "#E8D5A3"
  },
  "tokenColors": [
    {"scope": "comment","settings": {"foreground": "#5A4A28", "fontStyle": "italic"}},
    {"scope": "keyword.other.print.kemit","settings": {"foreground": "#F0C040", "fontStyle": "bold"}},
    {"scope": "storage.type.var.kemit","settings": {"foreground": "#C9A84C", "fontStyle": "bold"}},
    {"scope": "storage.type.function.kemit","settings": {"foreground": "#E08030", "fontStyle": "bold"}},
    {"scope": "storage.type.array.kemit","settings": {"foreground": "#80C0A0", "fontStyle": "bold"}},
    {"scope": "keyword.control.if.kemit","settings": {"foreground": "#D04060", "fontStyle": "bold"}},
    {"scope": "keyword.operator.assignment.kemit","settings": {"foreground": "#F0C040", "fontStyle": "bold"}},
    {"scope": "string","settings": {"foreground": "#80C060"}},
    {"scope": "constant.numeric.kemit","settings": {"foreground": "#60A8E0"}},
    {"scope": "constant.numeric.glyph.kemit","settings": {"foreground": "#80C0F0", "fontStyle": "bold"}},
    {"scope": "constant.language.boolean.true.kemit","settings": {"foreground": "#E08050"}},
    {"scope": "constant.language.null.kemit","settings": {"foreground": "#806040"}},
    {"scope": "support.function.builtin.kemit","settings": {"foreground": "#D060A0", "fontStyle": "bold"}},
    {"scope": "entity.name.function.kemit","settings": {"foreground": "#F0C040"}},
    {"scope": "variable.other.kemit","settings": {"foreground": "#E8D5A3"}},
    {"scope": "punctuation.separator.kemit","settings": {"foreground": "#5A4A20"}}
  ]
}
